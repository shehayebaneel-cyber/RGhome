// RG Home Aley — data model. Postgres on Neon.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Category {
  id        Int       @id @default(autoincrement())
  slug      String    @unique
  nameEn    String
  nameAr    String
  sortOrder Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id            Int         @id @default(autoincrement())
  categoryId    Int
  category      Category    @relation(fields: [categoryId], references: [id])
  brand         String
  nameEn        String
  nameAr        String
  descEn        String      @default("")
  descAr        String      @default("")
  price         Int // whole USD
  wasPrice      Int? // optional strike-through price
  tags          String      @default("") // comma-separated spec chips
  badgeEn       String      @default("")
  badgeAr       String      @default("")
  stock         Int         @default(0)
  isActive      Boolean     @default(true)
  isFeatured    Boolean     @default(false)
  sortOrder     Int         @default(0)
  orderItems    OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Order {
  id           Int         @id @default(autoincrement())
  reference    String      @unique
  customerName String
  phone        String
  address      String      @default("")
  town         String      @default("")
  note         String      @default("")
  paymentMethod String     @default("COD") // COD | INSTORE | (CARD later)
  status       String      @default("PENDING") // PENDING | CONFIRMED | DELIVERED | CANCELLED
  subtotal     Int         @default(0)
  deliveryFee  Int         @default(0)
  total        Int         @default(0)
  items        OrderItem[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId Int?
  product   Product? @relation(fields: [productId], references: [id])
  nameEn    String
  nameAr    String
  brand     String  @default("")
  price     Int
  qty       Int
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String   @default("")
  createdAt    DateTime @default(now())
}
